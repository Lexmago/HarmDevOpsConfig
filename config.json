{
  "buttons": [
    {
      "label": "Actualizar repo",
      "steps": [
        "git fetch origin main",
        "git checkout main",
        "git pull origin main",
        "git fetch --prune",
        "git config --global credential.helper manager"
      ]
    },
    {
      "label": "Crear rama",
      "steps": [
        "git checkout -b {{branch}}"
      ]
    },
    {
      "label": "Agregar cambios",
      "steps": [
        "git add ."
      ]
    },
    {
      "label": "Commit",
      "steps": [
        "git commit -m \"{{message}}\""
      ]
    },
    {
      "label": "Push",
      "steps": [
        "git push -u origin {{currentBranch}}"
      ]
    }
  ]
}
