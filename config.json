{
  "buttons": [
    {
      "label": "Actualizar repo",
      "steps": [
        "git fetch origin main",
        "git checkout main",
        "git reset --hard origin/main",
        "git fetch --prune"
      ]
    },
    {
      "label": "Crear rama",
      "steps": [
        "git checkout -b {{branch}}"
      ]
    },
    {
      "label": "Abrir VSCode",
      "steps": [
        "code ."
      ]
    },
    {
      "label": "Agregar cambios",
      "steps": [
        "git add ."
      ]
    },
    {
      "label": "Commit",
      "steps": [
        "git commit -m \"{{message}}\""
      ]
    },
    {
      "label": "Push",
      "steps": [
        "git push -u origin {{currentBranch}}"
      ]
    }
  ]
}
